
# ----------- Local deployment --------------
# NATS Auth Callout Configuration

# NATS server URL
NATS_URL=nats://nats:4222

# JWKS URL for OAuth2 token validation
JWKS_URL=http://keycloak.127-0-0-1.nip.io:8080/realms/auth-callout/protocol/openid-connect/certs
JWKS_ISSUER=http://keycloak.127-0-0-1.nip.io:8080/realms/auth-callout

# NATS keys (secrets - should come from Vault in production)
# Generate with: nsc generate nkey --operator
NATS_NKEY_SEED=SUAIBDPBAUTWCWBKIO6XHQNRCJ5NGKGPKK3NJ6Z3LXDQNTX53Q
NATS_ISSUER_SEED=SAANJIBNEKGCRUWSO5XKJYRJWO3PI5EANMJGM5QGLRTQ2EFRH3I
NATS_XKEY_SEED=SXAIBDPBAUTWCWBKIO6XHQNRCJ5NGKGPKK3NJ6Z3LXDQNTX53Q
