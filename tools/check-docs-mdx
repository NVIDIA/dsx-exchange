# Enforce MDX-safe markdown in docs/.
#
# Fern renders markdown through an MDX parser, which rejects constructs that
# are valid in plain markdown but invalid in JSX. This script catches the
# common violations before they reach CI or break versioned doc snapshots.
#
# Checks:
#   1. Non-self-closing void HTML elements (<br>, <hr>, <img>, etc.)
#   2. Bare { } outside fenced code blocks (MDX interprets as JSX expressions)
#   3. HTML comments (<!-- -->) outside fenced code blocks

set -euo pipefail

ERRORS=0
SEARCH_DIRS=("docs/")

if [[ $# -gt 0 ]]; then
  SEARCH_DIRS=("$@")
fi

VOID_ELEMENTS='img|br|hr|input|source|meta|link|area|base|col|embed|param|track|wbr'
for dir in "${SEARCH_DIRS[@]}"; do
  while IFS= read -r file; do
    [[ -z "${file}" ]] && continue
    while IFS= read -r match; do
      [[ -z "${match}" ]] && continue
      echo "MDX: non-self-closing void element: ${file}:${match}"
      ERRORS=$((ERRORS + 1))
    done < <(awk '
      /^```/ { in_fence = !in_fence; next }
      in_fence { next }
      { print NR": "$0 }
    ' "$file" | grep -E "<(${VOID_ELEMENTS})([[:space:]][^>]*)?" | grep -Ev "<(${VOID_ELEMENTS})([[:space:]][^>]*)?[[:space:]]*/>" || true)
  done < <(find "${dir}" -type f \( -name '*.md' -o -name '*.mdx' \) 2>/dev/null)
done

for dir in "${SEARCH_DIRS[@]}"; do
  while IFS= read -r file; do
    [[ -z "${file}" ]] && continue
    awk '
      function strip_jsx_comments(input, output, start, end) {
        output = ""
        while (length(input) > 0) {
          if (in_jsx_comment) {
            end = index(input, "*/}")
            if (end == 0) {
              return output
            }
            input = substr(input, end + 3)
            in_jsx_comment = 0
            continue
          }

          start = index(input, "{/*")
          if (start == 0) {
            output = output input
            return output
          }

          output = output substr(input, 1, start - 1)
          input = substr(input, start + 3)
          end = index(input, "*/}")
          if (end == 0) {
            in_jsx_comment = 1
            return output
          }
          input = substr(input, end + 3)
        }
        return output
      }

      /^```/ { in_fence = !in_fence; next }
      in_fence { next }
      {
        line = strip_jsx_comments($0)
        gsub(/`[^`]*`/, "", line)

        if (line ~ /(^|[^\\])\{/) {
          printf "MDX: bare { outside code fence: %s:%d: %s\n", FILENAME, NR, $0
          errors++
        }
        if (line ~ /<!--/) {
          printf "MDX: HTML comment outside code fence: %s:%d: %s\n", FILENAME, NR, $0
          errors++
        }
      }
      END { exit (errors > 0) ? 1 : 0 }
    ' "$file" 2>/dev/null
    if [[ $? -ne 0 ]]; then
      ERRORS=$((ERRORS + 1))
    fi
  done < <(find "${dir}" -type f \( -name '*.md' -o -name '*.mdx' \) 2>/dev/null)
done

if [[ ${ERRORS} -gt 0 ]]; then
  echo ""
  echo "ERROR: MDX safety violations found."
  echo ""
  echo "Common fixes:"
  echo "  <br>  → <br />        <img src=...>  → <img src=... />"
  echo "  {foo} → \\{foo\\}      <!-- ... -->   → remove or use {/* ... */}"
  exit 1
fi

echo "OK: all doc files are MDX-safe"
